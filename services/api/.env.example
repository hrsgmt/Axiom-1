# Copy this file to .env and fill in real values. .env is gitignored.

# Render Postgres "External Database URL" (or any Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Any long random string. Used to sign access tokens.
JWT_ACCESS_SECRET="change-me"

# A different long random string. Currently unused directly (refresh tokens
# are random bytes, not JWTs) but reserved for future use / rotation.
JWT_REFRESH_SECRET="change-me-too"
